<settings
		xmlns="http://maven.apache.org/SETTINGS/1.0.0"
		xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 http://maven.apache.org/xsd/settings-1.0.0.xsd"
>

	<servers>
		<server>
			<id>sbc</id>
			<username>${env.SBC_REPO_USERNAME}</username>
			<password>${env.SBC_REPO_PASSWORD}</password>
		</server>
		<server>
			<id>sbc-release</id>
			<username>${env.SBC_REPO_USERNAME}</username>
			<password>${env.SBC_REPO_PASSWORD}</password>
		</server>
		<server>
			<id>sbc-snapshot</id>
			<username>${env.SBC_REPO_USERNAME}</username>
			<password>${env.SBC_REPO_PASSWORD}</password>
		</server>
		<server>
			<id>sbc-mirror</id>
			<username>${env.SBC_REPO_USERNAME}</username>
			<password>${env.SBC_REPO_PASSWORD}</password>
		</server>
	</servers>

	<mirrors>
		<mirror>
			<id>sbc-mirror</id>
			<name>Mirror to South Branch Controls Maven Repository</name>
			<url>https://repo.southbranchcontrols.com/sbc</url>
			<mirrorOf>sbc</mirrorOf>
		</mirror>
		<mirror>
			<id>central-mirror</id>
			<name>Mirror to South Branch Controls Maven Repository</name>
			<url>https://repo.southbranchcontrols.com/central</url>
			<mirrorOf>central</mirrorOf>
		</mirror>
	</mirrors>

